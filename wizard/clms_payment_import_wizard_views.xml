<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_clms_payment_import_wizard_form" model="ir.ui.view">
        <field name="name">clms.payment.import.wizard.form</field>
        <field name="model">clms.payment.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import CLMS Dues Payments">
                <group invisible="state != 'upload'">
                    <group>
                        <field name="csv_file" filename="csv_filename"/>
                        <field name="csv_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="update_paid_to"/>
                        <field name="skip_existing"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>CLMS "Dues Payments by Date" Import</strong>
                        <p class="mb-0">
                            Upload the CSV exported from CLMS → Reports → Dues
                            Payments by Date. Each member payment will create a
                            dues payment record with proper GL coding, post a
                            journal entry, and optionally update the member's
                            paid-to date.
                        </p>
                    </div>
                </group>

                <group invisible="state != 'done'">
                    <field name="result_text" widget="text" nolabel="1"
                           colspan="2" readonly="1"/>
                </group>

                <field name="state" invisible="1"/>

                <footer>
                    <button name="action_import" string="Import Payments"
                            type="object" class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button string="Close" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_clms_payment_import_wizard" model="ir.actions.act_window">
        <field name="name">Import CLMS Dues Payments</field>
        <field name="res_model">clms.payment.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
