<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_budget_import_wizard_form" model="ir.ui.view">
        <field name="name">budget.import.wizard.form</field>
        <field name="model">budget.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Budget Lines">
                <group invisible="state != 'setup'">
                    <group>
                        <field name="import_mode" widget="radio"/>
                    </group>
                </group>

                <!-- CSV Import fields -->
                <group string="CSV File"
                       invisible="state != 'setup' or import_mode != 'csv'">
                    <group>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <group>
                        <button name="action_download_demo" type="object"
                                string="Download Demo CSV Template"
                                class="btn-link"
                                icon="fa-download"
                                invisible="state != 'setup'"/>
                        <field name="demo_csv" filename="demo_csv_name"
                               invisible="not demo_csv"/>
                        <field name="demo_csv_name" invisible="1"/>
                    </group>
                </group>

                <!-- QuickBooks Import Update fields -->
                <group string="QuickBooks P&amp;L File"
                       invisible="state != 'setup' or import_mode != 'qb_pnl'">
                    <group>
                        <field name="file_data" filename="file_name"
                               string="P&amp;L Export (.xlsx)"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <group>
                        <field name="skip_dues_accounts"/>
                        <div class="text-muted small" colspan="2">
                            Upload the QuickBooks Profit &amp; Loss XLSX export
                            to update budget lines. Letter subaccounts (A, B, C)
                            are auto-converted to numeric (01, 02, 03).
                            Member dues lines are skipped by default.
                        </div>
                    </group>
                </group>

                <!-- Roll-forward fields -->
                <group string="Roll Forward Settings"
                       invisible="state != 'setup' or import_mode != 'rollforward'">
                    <group>
                        <field name="source_budget_id"/>
                        <field name="adjustment_pct"
                               help="Increase expense lines by this %. Income lines are copied unchanged."/>
                    </group>
                </group>

                <!-- Common settings -->
                <group string="Target &amp; Options"
                       invisible="state != 'setup'">
                    <group>
                        <field name="target_budget_id"/>
                        <field name="overwrite"/>
                        <field name="create_missing_accounts"
                               invisible="import_mode == 'rollforward'"/>
                    </group>
                </group>

                <!-- Results -->
                <group invisible="state != 'done'">
                    <field name="result_message" readonly="1"
                           nolabel="1"/>
                </group>

                <footer invisible="state != 'setup'">
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button string="Close" class="btn-primary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_budget_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Budget Lines</field>
        <field name="res_model">budget.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
