<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================= -->
        <!-- Pre-printed slip serial sequences             -->
        <!--                                               -->
        <!-- Each "Print Blank" pulls the next serial so   -->
        <!-- paper slips have unique numbers whether or    -->
        <!-- not they ever get digitized.                  -->
        <!-- ============================================= -->

        <record id="seq_cash_count_slip" model="ir.sequence">
            <field name="name">Cash Count Slip</field>
            <field name="code">elks.cash.count.slip</field>
            <field name="prefix">CC</field>
            <field name="padding">6</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_cash_movement_change" model="ir.sequence">
            <field name="name">Change Request / Order Slip</field>
            <field name="code">elks.cash.movement.slip.change</field>
            <field name="prefix">CHG</field>
            <field name="padding">6</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_cash_movement_till_deposit" model="ir.sequence">
            <field name="name">Till Deposit Slip</field>
            <field name="code">elks.cash.movement.slip.till_deposit</field>
            <field name="prefix">TLD</field>
            <field name="padding">6</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_cash_movement_bank_deposit" model="ir.sequence">
            <field name="name">Bank Deposit Slip</field>
            <field name="code">elks.cash.movement.slip.bank_deposit</field>
            <field name="prefix">BD</field>
            <field name="padding">6</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_cash_movement_bank_stock" model="ir.sequence">
            <field name="name">Bank Stock-Up Slip</field>
            <field name="code">elks.cash.movement.slip.bank_stock</field>
            <field name="prefix">BS</field>
            <field name="padding">6</field>
            <field name="implementation">no_gap</field>
        </record>

        <!-- ============================================= -->
        <!-- Cron: archive event_till locations            -->
        <!-- ============================================= -->
        <record id="cron_archive_event_tills" model="ir.cron">
            <field name="name">Cash Mgmt: archive expired Event Tills</field>
            <field name="model_id" ref="model_elks_cash_location"/>
            <field name="state">code</field>
            <field name="code">model._cron_archive_old_event_tills()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
