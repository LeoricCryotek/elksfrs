<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Create monthly FRS submission records on the 1st of each month -->
        <record id="ir_cron_frs_create_submission" model="ir.cron">
            <field name="name">Elks FRS: Create Monthly Submission</field>
            <field name="model_id" ref="model_elks_frs_submission"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_monthly_submission()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Check for overdue FRS submissions weekly -->
        <record id="ir_cron_frs_check_overdue" model="ir.cron">
            <field name="name">Elks FRS: Check Overdue Submissions</field>
            <field name="model_id" ref="model_elks_frs_submission"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_overdue()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Sequence for journal entry numbers -->
        <record id="seq_elks_journal_entry" model="ir.sequence">
            <field name="name">Elks Journal Entry</field>
            <field name="code">elks.journal.entry</field>
            <field name="prefix">EJE/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
