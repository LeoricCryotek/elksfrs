<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         DAILY BATCH views
         ============================================================ -->

    <record id="view_elks_daily_batch_tree" model="ir.ui.view">
        <field name="name">elks.daily.batch.tree</field>
        <field name="model">elks.dues.deposit</field>
        <field name="arch" type="xml">
            <list string="Daily Batches"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'deposited'"
                  decoration-warning="state == 'closed'"
                  decoration-muted="state == 'cancelled'">
                <field name="batch_date"/>
                <field name="name"/>
                <field name="payment_count"/>
                <field name="expected_total" sum="Total"/>
                <field name="bank_deposit_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'closed'"
                       decoration-success="state == 'deposited'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_elks_daily_batch_form" model="ir.ui.view">
        <field name="name">elks.daily.batch.form</field>
        <field name="model">elks.dues.deposit</field>
        <field name="arch" type="xml">
            <form string="Daily Batch">
                <header>
                    <button name="action_post_and_close" type="object"
                            string="Close Batch &amp; Post Payments"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will post all draft payments and lock the batch. Continue?"/>
                    <button name="action_reopen" type="object"
                            string="Re-open Batch"
                            invisible="state != 'closed'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('deposited', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,closed,deposited"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="batch_date"
                                   readonly="state != 'draft'"/>
                            <field name="prepared_by"/>
                        </group>
                        <group>
                            <field name="payment_count"/>
                            <field name="expected_total"/>
                            <field name="bank_deposit_id"
                                   invisible="not bank_deposit_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payments">
                            <field name="payment_ids"
                                   readonly="state != 'draft'">
                                <list>
                                    <field name="payment_date"/>
                                    <field name="partner_id"/>
                                    <field name="member_number"/>
                                    <field name="payment_type"/>
                                    <field name="check_number"/>
                                    <field name="amount_total" sum="Total"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"
                                   placeholder="Batch notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_elks_daily_batch_search" model="ir.ui.view">
        <field name="name">elks.daily.batch.search</field>
        <field name="model">elks.dues.deposit</field>
        <field name="arch" type="xml">
            <search>
                <field name="batch_date"/>
                <field name="name"/>
                <separator/>
                <filter name="open" string="Open"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="closed" string="Closed"
                        domain="[('state', '=', 'closed')]"/>
                <filter name="deposited" string="Deposited"
                        domain="[('state', '=', 'deposited')]"/>
                <filter name="undeposited" string="Undeposited"
                        domain="[('state', 'in', ('draft', 'closed'))]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_date" string="Batch Date"
                            context="{'group_by': 'batch_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Keep old XML ID as alias for backward compat -->
    <record id="action_elks_dues_deposit" model="ir.actions.act_window">
        <field name="name">Daily Batches</field>
        <field name="res_model">elks.dues.deposit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_elks_daily_batch_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first daily batch
            </p>
            <p>
                Daily batches collect payments received each day.
                Close a batch to lock it, then add it to a Bank Deposit
                when ready to go to the bank.
            </p>
        </field>
    </record>


    <!-- ============================================================
         BANK DEPOSIT views
         ============================================================ -->

    <record id="view_elks_bank_deposit_tree" model="ir.ui.view">
        <field name="name">elks.bank.deposit.tree</field>
        <field name="model">elks.bank.deposit</field>
        <field name="arch" type="xml">
            <list string="Bank Deposits"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'signed'"
                  decoration-success="state == 'deposited'"
                  decoration-muted="state == 'cancelled'">
                <field name="deposit_date"/>
                <field name="name"/>
                <field name="bank_reference"/>
                <field name="batch_count"/>
                <field name="expected_total" sum="Expected"/>
                <field name="bank_confirmed_total" sum="Confirmed"/>
                <field name="variance" sum="Variance"
                       decoration-danger="variance != 0"/>
                <field name="treasurer_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'signed'"
                       decoration-success="state == 'deposited'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_elks_bank_deposit_form" model="ir.ui.view">
        <field name="name">elks.bank.deposit.form</field>
        <field name="model">elks.bank.deposit</field>
        <field name="arch" type="xml">
            <form string="Bank Deposit">
                <header>
                    <button name="action_treasurer_sign_off" type="object"
                            string="Treasurer Sign-Off"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_mark_received" type="object"
                            string="Mark Received"
                            invisible="state != 'signed'"
                            class="btn-secondary"/>
                    <button name="action_confirm_deposited" type="object"
                            string="Confirm Deposited at Bank"
                            class="btn-primary"
                            invisible="state != 'signed'"
                            confirm="This will permanently lock all linked batches. Continue?"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('deposited', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,signed,deposited"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="deposit_date"
                                   readonly="state != 'draft'"/>
                            <field name="bank_reference"/>
                            <field name="prepared_by"/>
                        </group>
                        <group>
                            <field name="batch_count"/>
                            <field name="expected_total"/>
                            <field name="bank_confirmed_total"
                                   readonly="state == 'deposited'"/>
                            <field name="variance"
                                   decoration-danger="variance != 0"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Sign-Off"
                           invisible="state == 'draft'">
                        <group>
                            <field name="treasurer_id" readonly="1"/>
                            <field name="treasurer_sign_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="received_by"
                                   readonly="state == 'deposited'"/>
                            <field name="received_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Daily Batches">
                            <field name="batch_ids"
                                   readonly="state != 'draft'">
                                <list>
                                    <field name="batch_date"/>
                                    <field name="name"/>
                                    <field name="payment_count"/>
                                    <field name="expected_total" sum="Total"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"
                                   placeholder="Deposit notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_elks_bank_deposit_search" model="ir.ui.view">
        <field name="name">elks.bank.deposit.search</field>
        <field name="model">elks.bank.deposit</field>
        <field name="arch" type="xml">
            <search>
                <field name="deposit_date"/>
                <field name="bank_reference"/>
                <field name="treasurer_id"/>
                <separator/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="signed" string="Signed Off"
                        domain="[('state', '=', 'signed')]"/>
                <filter name="deposited" string="Deposited"
                        domain="[('state', '=', 'deposited')]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Deposit Month"
                            context="{'group_by': 'deposit_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_elks_bank_deposit" model="ir.actions.act_window">
        <field name="name">Bank Deposits</field>
        <field name="res_model">elks.bank.deposit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_elks_bank_deposit_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a bank deposit
            </p>
            <p>
                Group closed daily batches into a bank deposit.
                The Treasurer signs off, a runner receives it, and
                it's confirmed once the bank processes it.
            </p>
        </field>
    </record>


    <!-- ============================================================
         CASH ON HAND views
         ============================================================ -->

    <record id="view_elks_cash_on_hand_tree" model="ir.ui.view">
        <field name="name">elks.cash.on.hand.tree</field>
        <field name="model">elks.cash.on.hand</field>
        <field name="arch" type="xml">
            <list string="Cash On Hand Counts"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'done' and not has_variance"
                  decoration-danger="state == 'done' and has_variance"
                  decoration-muted="state == 'cancelled'">
                <field name="count_date"/>
                <field name="count_type"/>
                <field name="expected_cash"/>
                <field name="total_coins" optional="show"/>
                <field name="total_bills" optional="show"/>
                <field name="counted_total" sum="Total"/>
                <field name="variance"
                       decoration-danger="has_variance"/>
                <field name="counted_by"/>
                <field name="witnessed_by"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_elks_cash_on_hand_form" model="ir.ui.view">
        <field name="name">elks.cash.on.hand.form</field>
        <field name="model">elks.cash.on.hand</field>
        <field name="arch" type="xml">
            <form string="Cash On Hand Count">
                <header>
                    <button name="action_refresh_expected" type="object"
                            string="Refresh Expected Total"
                            invisible="state != 'draft'"
                            class="btn-secondary"/>
                    <button name="action_finalize" type="object"
                            string="Finalize Count"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will lock the count. Continue?"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Count Details">
                            <field name="count_date"
                                   readonly="state != 'draft'"/>
                            <field name="count_type"
                                   readonly="state != 'draft'"/>
                            <field name="counted_by"
                                   readonly="state != 'draft'"/>
                            <field name="witnessed_by"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Expected vs. Counted">
                            <field name="expected_cash"/>
                            <field name="counted_total"/>
                            <field name="variance"
                                   decoration-danger="has_variance"/>
                            <field name="has_variance" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- ========== COIN COUNTS ========== -->
                    <group string="Coins"
                           readonly="state != 'draft'">
                        <group>
                            <label for="qty_pennies"/>
                            <div class="o_row">
                                <field name="qty_pennies" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $0.01  =</span>
                                <field name="sub_pennies" class="oe_inline"/>
                            </div>
                            <label for="qty_nickels"/>
                            <div class="o_row">
                                <field name="qty_nickels" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $0.05  =</span>
                                <field name="sub_nickels" class="oe_inline"/>
                            </div>
                            <label for="qty_dimes"/>
                            <div class="o_row">
                                <field name="qty_dimes" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $0.10  =</span>
                                <field name="sub_dimes" class="oe_inline"/>
                            </div>
                        </group>
                        <group>
                            <label for="qty_quarters"/>
                            <div class="o_row">
                                <field name="qty_quarters" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $0.25  =</span>
                                <field name="sub_quarters" class="oe_inline"/>
                            </div>
                            <label for="qty_half_dollars"/>
                            <div class="o_row">
                                <field name="qty_half_dollars" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $0.50  =</span>
                                <field name="sub_half_dollars" class="oe_inline"/>
                            </div>
                            <label for="qty_dollar_coins"/>
                            <div class="o_row">
                                <field name="qty_dollar_coins" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $1.00  =</span>
                                <field name="sub_dollar_coins" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group/>
                        <group>
                            <field name="total_coins"
                                   class="fw-bold"/>
                        </group>
                    </group>

                    <!-- ========== BILL COUNTS ========== -->
                    <group string="Bills"
                           readonly="state != 'draft'">
                        <group>
                            <label for="qty_ones"/>
                            <div class="o_row">
                                <field name="qty_ones" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $1  =</span>
                                <field name="sub_ones" class="oe_inline"/>
                            </div>
                            <label for="qty_twos"/>
                            <div class="o_row">
                                <field name="qty_twos" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $2  =</span>
                                <field name="sub_twos" class="oe_inline"/>
                            </div>
                            <label for="qty_fives"/>
                            <div class="o_row">
                                <field name="qty_fives" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $5  =</span>
                                <field name="sub_fives" class="oe_inline"/>
                            </div>
                            <label for="qty_tens"/>
                            <div class="o_row">
                                <field name="qty_tens" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $10  =</span>
                                <field name="sub_tens" class="oe_inline"/>
                            </div>
                        </group>
                        <group>
                            <label for="qty_twenties"/>
                            <div class="o_row">
                                <field name="qty_twenties" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $20  =</span>
                                <field name="sub_twenties" class="oe_inline"/>
                            </div>
                            <label for="qty_fifties"/>
                            <div class="o_row">
                                <field name="qty_fifties" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $50  =</span>
                                <field name="sub_fifties" class="oe_inline"/>
                            </div>
                            <label for="qty_hundreds"/>
                            <div class="o_row">
                                <field name="qty_hundreds" class="oe_inline"/>
                                <span class="text-muted ms-2">×  $100  =</span>
                                <field name="sub_hundreds" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group/>
                        <group>
                            <field name="total_bills"
                                   class="fw-bold"/>
                        </group>
                    </group>

                    <!-- ========== GRAND TOTAL ========== -->
                    <group>
                        <group/>
                        <group>
                            <field name="total_denomination"
                                   class="fw-bold fs-4"/>
                        </group>
                    </group>

                    <!-- ========== DEPOSIT / CHANGE ORDER ANALYSIS ========== -->
                    <separator string="Deposit &amp; Change Order Analysis"/>
                    <group>
                        <group string="Coins — Over / Under Par">
                            <label for="over_pennies"/>
                            <div class="o_row">
                                <field name="over_pennies" class="oe_inline"
                                       decoration-success="over_pennies &gt; 0"
                                       decoration-danger="over_pennies &lt; 0"/>
                                <span class="text-muted ms-1">pennies</span>
                            </div>
                            <label for="over_nickels"/>
                            <div class="o_row">
                                <field name="over_nickels" class="oe_inline"
                                       decoration-success="over_nickels &gt; 0"
                                       decoration-danger="over_nickels &lt; 0"/>
                                <span class="text-muted ms-1">nickels</span>
                            </div>
                            <label for="over_dimes"/>
                            <div class="o_row">
                                <field name="over_dimes" class="oe_inline"
                                       decoration-success="over_dimes &gt; 0"
                                       decoration-danger="over_dimes &lt; 0"/>
                                <span class="text-muted ms-1">dimes</span>
                            </div>
                            <label for="over_quarters"/>
                            <div class="o_row">
                                <field name="over_quarters" class="oe_inline"
                                       decoration-success="over_quarters &gt; 0"
                                       decoration-danger="over_quarters &lt; 0"/>
                                <span class="text-muted ms-1">quarters</span>
                            </div>
                            <label for="over_half_dollars"/>
                            <div class="o_row">
                                <field name="over_half_dollars" class="oe_inline"
                                       decoration-success="over_half_dollars &gt; 0"
                                       decoration-danger="over_half_dollars &lt; 0"/>
                                <span class="text-muted ms-1">half dollars</span>
                            </div>
                            <label for="over_dollar_coins"/>
                            <div class="o_row">
                                <field name="over_dollar_coins" class="oe_inline"
                                       decoration-success="over_dollar_coins &gt; 0"
                                       decoration-danger="over_dollar_coins &lt; 0"/>
                                <span class="text-muted ms-1">dollar coins</span>
                            </div>
                        </group>
                        <group string="Bills — Over / Under Par">
                            <label for="over_ones"/>
                            <div class="o_row">
                                <field name="over_ones" class="oe_inline"
                                       decoration-success="over_ones &gt; 0"
                                       decoration-danger="over_ones &lt; 0"/>
                                <span class="text-muted ms-1">$1 bills</span>
                            </div>
                            <label for="over_twos"/>
                            <div class="o_row">
                                <field name="over_twos" class="oe_inline"
                                       decoration-success="over_twos &gt; 0"
                                       decoration-danger="over_twos &lt; 0"/>
                                <span class="text-muted ms-1">$2 bills</span>
                            </div>
                            <label for="over_fives"/>
                            <div class="o_row">
                                <field name="over_fives" class="oe_inline"
                                       decoration-success="over_fives &gt; 0"
                                       decoration-danger="over_fives &lt; 0"/>
                                <span class="text-muted ms-1">$5 bills</span>
                            </div>
                            <label for="over_tens"/>
                            <div class="o_row">
                                <field name="over_tens" class="oe_inline"
                                       decoration-success="over_tens &gt; 0"
                                       decoration-danger="over_tens &lt; 0"/>
                                <span class="text-muted ms-1">$10 bills</span>
                            </div>
                            <label for="over_twenties"/>
                            <div class="o_row">
                                <field name="over_twenties" class="oe_inline"
                                       decoration-success="over_twenties &gt; 0"
                                       decoration-danger="over_twenties &lt; 0"/>
                                <span class="text-muted ms-1">$20 bills</span>
                            </div>
                            <label for="over_fifties"/>
                            <div class="o_row">
                                <field name="over_fifties" class="oe_inline"
                                       decoration-success="over_fifties &gt; 0"
                                       decoration-danger="over_fifties &lt; 0"/>
                                <span class="text-muted ms-1">$50 bills</span>
                            </div>
                            <label for="over_hundreds"/>
                            <div class="o_row">
                                <field name="over_hundreds" class="oe_inline"
                                       decoration-success="over_hundreds &gt; 0"
                                       decoration-danger="over_hundreds &lt; 0"/>
                                <span class="text-muted ms-1">$100 bills</span>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="total_to_deposit"
                                   class="fw-bold text-success fs-5"
                                   string="Total to Deposit"/>
                        </group>
                        <group>
                            <field name="total_change_order"
                                   class="fw-bold text-danger fs-5"
                                   string="Change Order Needed"/>
                        </group>
                    </group>

                    <group string="Variance Resolution"
                           invisible="not has_variance">
                        <field name="variance_explanation"
                               placeholder="Explain the discrepancy..."
                               readonly="state != 'draft'"/>
                        <field name="adjustment_amount"
                               invisible="state != 'done'"/>
                        <field name="adjustment_date"
                               invisible="state != 'done'"/>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="note"
                                   placeholder="Count notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_elks_cash_on_hand_search" model="ir.ui.view">
        <field name="name">elks.cash.on.hand.search</field>
        <field name="model">elks.cash.on.hand</field>
        <field name="arch" type="xml">
            <search>
                <field name="count_date"/>
                <field name="counted_by"/>
                <separator/>
                <filter name="semi_annual" string="Semi-Annual"
                        domain="[('count_type', '=', 'semi_annual')]"/>
                <filter name="adhoc" string="Ad-Hoc"
                        domain="[('count_type', '=', 'adhoc')]"/>
                <separator/>
                <filter name="has_variance" string="Has Variance"
                        domain="[('has_variance', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_elks_cash_on_hand" model="ir.actions.act_window">
        <field name="name">Cash On Hand Counts</field>
        <field name="res_model">elks.cash.on.hand</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_elks_cash_on_hand_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a cash on hand count
            </p>
            <p>
                Count physical cash and checks held at the lodge.
                The system compares your count against the expected
                amount from undeposited daily batches.
