<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Cash On Hand form — add Register Count Lines + Transfers
         ============================================================ -->
    <record id="view_elks_cash_on_hand_form_registers"
            model="ir.ui.view">
        <field name="name">elks.cash.on.hand.form.registers</field>
        <field name="model">elks.cash.on.hand</field>
        <field name="inherit_id" ref="view_elks_cash_on_hand_form"/>
        <field name="arch" type="xml">

            <!-- Add Print Treasurer Report button to header -->
            <xpath expr="//button[@name='action_finalize']" position="after">
                <button name="action_print_treasurer_report" type="object"
                        string="Treasurer Report"
                        class="btn-secondary"
                        invisible="state != 'done'"
                        icon="fa-print"/>
            </xpath>

            <!-- Add register summary fields after Count Details group -->
            <xpath expr="//group[@string='Expected vs. Counted']" position="before">
                <group string="Register Summary">
                    <field name="register_count"/>
                    <field name="total_starter_banks"/>
                    <field name="total_excess"/>
                </group>
            </xpath>

            <!-- Replace the notebook with expanded version including register tabs -->
            <xpath expr="//notebook" position="replace">
                <notebook>
                    <page string="Register Counts" name="register_counts">
                        <field name="register_line_ids"
                               readonly="state != 'draft'">
                            <list string="Register Counts" editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="register_id"/>
                                <field name="qty_pennies" optional="hide"/>
                                <field name="qty_nickels" optional="hide"/>
                                <field name="qty_dimes" optional="hide"/>
                                <field name="qty_quarters" optional="hide"/>
                                <field name="qty_half_dollars" optional="hide"/>
                                <field name="qty_dollar_coins" optional="hide"/>
                                <field name="qty_ones" optional="hide"/>
                                <field name="qty_twos" optional="hide"/>
                                <field name="qty_fives" optional="hide"/>
                                <field name="qty_tens" optional="hide"/>
                                <field name="qty_twenties" optional="hide"/>
                                <field name="qty_fifties" optional="hide"/>
                                <field name="qty_hundreds" optional="hide"/>
                                <field name="counted_total" sum="Total Counted"/>
                                <field name="starter_total" sum="Total Starter"/>
                                <field name="excess_total" sum="Total Excess"
                                       decoration-success="excess_total &gt; 0"
                                       decoration-danger="excess_total &lt; 0"/>
                                <field name="currency_id" column_invisible="True"/>
                            </list>
                            <form string="Register Count">
                                <group>
                                    <group>
                                        <field name="register_id"/>
                                        <field name="currency_id" invisible="1"/>
                                    </group>
                                    <group>
                                        <field name="counted_total" class="fw-bold"/>
                                        <field name="starter_total"/>
                                        <field name="excess_total" class="fw-bold"
                                               decoration-success="excess_total &gt; 0"
                                               decoration-danger="excess_total &lt; 0"/>
                                    </group>
                                </group>
                                <group string="Coins Counted">
                                    <group>
                                        <label for="qty_pennies"/>
                                        <div class="o_row">
                                            <field name="qty_pennies" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $0.01</span>
                                        </div>
                                        <label for="qty_nickels"/>
                                        <div class="o_row">
                                            <field name="qty_nickels" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $0.05</span>
                                        </div>
                                        <label for="qty_dimes"/>
                                        <div class="o_row">
                                            <field name="qty_dimes" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $0.10</span>
                                        </div>
                                    </group>
                                    <group>
                                        <label for="qty_quarters"/>
                                        <div class="o_row">
                                            <field name="qty_quarters" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $0.25</span>
                                        </div>
                                        <label for="qty_half_dollars"/>
                                        <div class="o_row">
                                            <field name="qty_half_dollars" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $0.50</span>
                                        </div>
                                        <label for="qty_dollar_coins"/>
                                        <div class="o_row">
                                            <field name="qty_dollar_coins" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $1.00</span>
                                        </div>
                                    </group>
                                </group>
                                <group string="Bills Counted">
                                    <group>
                                        <label for="qty_ones"/>
                                        <div class="o_row">
                                            <field name="qty_ones" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $1</span>
                                        </div>
                                        <label for="qty_twos"/>
                                        <div class="o_row">
                                            <field name="qty_twos" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $2</span>
                                        </div>
                                        <label for="qty_fives"/>
                                        <div class="o_row">
                                            <field name="qty_fives" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $5</span>
                                        </div>
                                        <label for="qty_tens"/>
                                        <div class="o_row">
                                            <field name="qty_tens" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $10</span>
                                        </div>
                                    </group>
                                    <group>
                                        <label for="qty_twenties"/>
                                        <div class="o_row">
                                            <field name="qty_twenties" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $20</span>
                                        </div>
                                        <label for="qty_fifties"/>
                                        <div class="o_row">
                                            <field name="qty_fifties" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $50</span>
                                        </div>
                                        <label for="qty_hundreds"/>
                                        <div class="o_row">
                                            <field name="qty_hundreds" class="oe_inline"/>
                                            <span class="text-muted ms-2">×  $100</span>
                                        </div>
                                    </group>
                                </group>
                                <group string="Starter Bank Snapshot">
                                    <group>
                                        <field name="starter_pennies"/>
                                        <field name="starter_nickels"/>
                                        <field name="starter_dimes"/>
                                        <field name="starter_quarters"/>
                                        <field name="starter_half_dollars"/>
                                        <field name="starter_dollar_coins"/>
                                    </group>
                                    <group>
                                        <field name="starter_ones"/>
                                        <field name="starter_twos"/>
                                        <field name="starter_fives"/>
                                        <field name="starter_tens"/>
                                        <field name="starter_twenties"/>
                                        <field name="starter_fifties"/>
                                        <field name="starter_hundreds"/>
                                    </group>
                                </group>
                            </form>
                        </field>
                    </page>

                    <page string="Transfers" name="transfers">
                        <field name="transfer_ids"
                               readonly="state != 'draft'">
                            <list string="Cash Transfers" editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="from_register_id"/>
                                <field name="to_register_id"/>
                                <field name="qty_ones" string="$1" optional="show"/>
                                <field name="qty_fives" string="$5" optional="show"/>
                                <field name="qty_tens" string="$10" optional="show"/>
                                <field name="qty_twenties" string="$20" optional="show"/>
                                <field name="qty_quarters" string="25¢" optional="hide"/>
                                <field name="qty_pennies" string="1¢" optional="hide"/>
                                <field name="qty_nickels" string="5¢" optional="hide"/>
                                <field name="qty_dimes" string="10¢" optional="hide"/>
                                <field name="qty_half_dollars" string="50¢" optional="hide"/>
                                <field name="qty_dollar_coins" string="$1c" optional="hide"/>
                                <field name="qty_twos" string="$2" optional="hide"/>
                                <field name="qty_fifties" string="$50" optional="hide"/>
                                <field name="qty_hundreds" string="$100" optional="hide"/>
                                <field name="transfer_total" sum="Total Transfers"/>
                                <field name="currency_id" column_invisible="True"/>
                            </list>
                        </field>
                    </page>

                    <page string="Deposit / Change Order" name="deposit_change">
                        <group>
                            <group string="Deposit to Bank (over par)">
                                <field name="deposit_pennies"
                                       invisible="deposit_pennies == 0"/>
                                <field name="deposit_nickels"
                                       invisible="deposit_nickels == 0"/>
                                <field name="deposit_dimes"
                                       invisible="deposit_dimes == 0"/>
                                <field name="deposit_quarters"
                                       invisible="deposit_quarters == 0"/>
                                <field name="deposit_half_dollars"
                                       invisible="deposit_half_dollars == 0"/>
                                <field name="deposit_dollar_coins"
                                       invisible="deposit_dollar_coins == 0"/>
                                <field name="deposit_ones"
                                       invisible="deposit_ones == 0"/>
                                <field name="deposit_twos"
                                       invisible="deposit_twos == 0"/>
                                <field name="deposit_fives"
                                       invisible="deposit_fives == 0"/>
                                <field name="deposit_tens"
                                       invisible="deposit_tens == 0"/>
                                <field name="deposit_twenties"
                                       invisible="deposit_twenties == 0"/>
                                <field name="deposit_fifties"
                                       invisible="deposit_fifties == 0"/>
                                <field name="deposit_hundreds"
                                       invisible="deposit_hundreds == 0"/>
                                <field name="deposit_total_denom"
                                       class="fw-bold text-success fs-5"
                                       string="TOTAL DEPOSIT"/>
                            </group>
                            <group string="Change Order from Bank (under par)">
                                <field name="change_pennies"
                                       invisible="change_pennies == 0"/>
                                <field name="change_nickels"
                                       invisible="change_nickels == 0"/>
                                <field name="change_dimes"
                                       invisible="change_dimes == 0"/>
                                <field name="change_quarters"
                                       invisible="change_quarters == 0"/>
                                <field name="change_half_dollars"
                                       invisible="change_half_dollars == 0"/>
                                <field name="change_dollar_coins"
                                       invisible="change_dollar_coins == 0"/>
                                <field name="change_ones"
                                       invisible="change_ones == 0"/>
                                <field name="change_twos"
                                       invisible="change_twos == 0"/>
                                <field name="change_fives"
                                       invisible="change_fives == 0"/>
                                <field name="change_tens"
                                       invisible="change_tens == 0"/>
                                <field name="change_twenties"
                                       invisible="change_twenties == 0"/>
                                <field name="change_fifties"
                                       invisible="change_fifties == 0"/>
                                <field name="change_hundreds"
                                       invisible="change_hundreds == 0"/>
                                <field name="change_total_denom"
                                       class="fw-bold text-danger fs-5"
                                       string="CHANGE ORDER"/>
                            </group>
                        </group>
                    </page>

                    <page string="Notes" name="notes">
                        <field name="note"
                               placeholder="Count notes..."/>
                    </page>
                </notebook>
            </xpath>

        </field>
    </record>

    <!-- ============================================================
         Cash On Hand list — add register count column
         ============================================================ -->
    <record id="view_elks_cash_on_hand_tree_registers"
            model="ir.ui.view">
        <field name="name">elks.cash.on.hand.tree.registers</field>
        <field name="model">elks.cash.on.hand</field>
        <field name="inherit_id" ref="view_elks_cash_on_hand_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='count_type']" position="after">
                <field name="register_count" optional="show"
                       string="Registers"/>
            </xpath>
            <xpath expr="//field[@name='counted_total']" position="after">
                <field name="deposit_total_denom" optional="show"
                       string="Deposit" sum="Deposit"/>
                <field name="change_total_denom" optional="show"
                       string="Change Order" sum="Change"/>
            </xpath>
        </field>
    </record>

</odoo>
